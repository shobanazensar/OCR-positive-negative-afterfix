# Environment Configuration
# Copy this file to .env and update values

# Application URL
BASE_URL=https://digital-onboarding-fe.bravesky-d9f9eeb7.eastus2.azurecontainerapps.io/

# Debug mode (enables verbose logging)
DEBUG=false

# Browser settings
HEADLESS=true
SLOW_MO=0

# Test timeout (ms)
TEST_TIMEOUT=30000

# Retry failed tests
RETRIES=1

# Parallel workers
WORKERS=4
